    "raid10": {
      "sequential_read_scale": 1.9,
      "sequential_write_scale": 0.95,
      "random_read_scale": 1.9,
      "random_write_scale": 0.95,
      "usable_ratio": 0.5,
      "note": "Best overall performance. Recommended for Veeam and mixed workloads."
    },
    "raid50": {
      "sequential_read_scale": 1.6,
      "sequential_write_scale": 0.70,
      "random_read_scale": 1.5,
      "random_write_scale": 0.35,
      "note": "Good for large sequential (backup). Write penalty less than RAID5 due to striping."
    },
    "raid60": {
      "sequential_read_scale": 1.5,
      "sequential_write_scale": 0.60,
      "random_read_scale": 1.4,
      "random_write_scale": 0.28
