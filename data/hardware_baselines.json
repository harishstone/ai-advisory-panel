  "raid_multipliers": {
    "_comment": "Applied to single-disk baselines scaled by drive count",
    "raid1": {
      "sequential_read_scale": 1.8,
      "sequential_write_scale": 0.9,
      "random_read_scale": 1.8,
      "random_write_scale": 0.9,
      "usable_ratio": 0.5
    },
    "raid5": {
      "sequential_read_scale": 0.85,
      "sequential_write_scale": 0.65,
      "random_read_scale": 0.80,
      "random_write_scale": 0.25,
      "usable_ratio_formula": "(n-1)/n",
      "note": "Write penalty: parity read-modify-write. Random write severely impacted."
    },
    "raid6": {
      "sequential_read_scale": 0.80,
      "sequential_write_scale": 0.55,
      "random_read_scale": 0.75,
      "random_write_scale": 0.18,
      "usable_ratio_formula": "(n-2)/n",
      "note": "Double parity. Even heavier write penalty than RAID 5."
